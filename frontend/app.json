{
  "expo": {
    "name": "IsdaOK",
    "slug": "IsdaOK",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "isdaok",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#8ccdeb"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID for authentication"
      }
    },
    "android": {
      "permissions": [
        "USE_BIOMETRIC"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#8ccdeb",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.hollowrithm.isdaok"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",[
        "expo-media-library",{
          "photosPermission": "Allow IsdaOK to access your photos.",
          "savePhotosPermission": "Allow IsdaOK to save photos",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8da59615-fca7-4b18-9fbb-2e9e5b549ad5"
      }
    }
  }
}
